# Force 256 colors for Terminal.app compatibility
set -g default-terminal "screen-256color"

# Gruvbox Dark (Basic 256-color palette)
set -g status-style 'bg=#282828 fg=#ebdbb2' # Dark gray bg, light cream fg

# Active window highlight (Gruvbox yellow/gold)
set-window-option -g window-status-current-style 'fg=#fabd2f bg=#3c3836 bold'

# Pane borders (Gruvbox gray and green)
set -g pane-border-style 'fg=#3c3836'
set -g pane-active-border-style 'fg=#b8bb26'

set -g prefix C-a
unbind C-b
bind-key C-a send-prefix

set -s escape-time 0

# Enable Vi mode for scrolling and copying
set-window-option -g mode-keys vi
set -g set-clipboard on

# Make tmux copy mode feel closer to Vim.
bind-key -T copy-mode-vi v send-keys -X begin-selection
bind-key -T copy-mode-vi Enter send-keys -X copy-pipe-and-cancel "pbcopy"
bind-key -T copy-mode-vi y send-keys -X copy-pipe-and-cancel "pbcopy"

# Vim-style pane selection
bind -r k select-pane -U
bind -r j select-pane -D
bind -r h select-pane -L
bind -r l select-pane -R

# Easy config reload
bind r source-file ~/.tmux.conf \; display "Reloaded!"

# Enable mouse for easy scrolling
set -g mouse on

# tmux plugins
set -g @plugin 'tmux-plugins/tpm'
set -g @plugin 'tmux-plugins/tmux-resurrect'
set -g @plugin 'tmux-plugins/tmux-continuum'
set -g @plugin 'alexwforsythe/tmux-which-key'

# Persist sessions automatically and restore them on tmux start.
set -g @continuum-restore 'on'
set -g @resurrect-strategy-nvim 'session'

# Keep tpm at the bottom of tmux.conf
run '~/.tmux/plugins/tpm/tpm'
